<Window x:Class="DesktopMessageApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="800" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
            <TextBlock Text="数据来源：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="QuickFormRadio" Content="QuickForm" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton x:Name="LocalRadio" Content="本地"/>
            </StackPanel>
            
            <TextBlock Text="班主任寄语（每行一条）：" Margin="0,10,0,5"/>
            <TextBox x:Name="MessageTextBox" Height="120" AcceptsReturn="True" TextWrapping="Wrap"/>
            
            <TextBlock Text="倒计时名称：" Margin="0,10,0,5"/>
            <TextBox x:Name="CountdownNameTextBox"/>
            
            <TextBlock Text="寄语字号：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="FontSizeSlider" Minimum="12" Maximum="50" Value="18" Width="200"/>
                <TextBlock x:Name="FontSizeValueText" Text="18" Margin="10,0,0,0"/>
            </StackPanel>
            
            <TextBlock Text="倒计时字号：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="CountdownFontSizeSlider" Minimum="12" Maximum="50" Value="20" Width="200"/>
                <TextBlock x:Name="CountdownFontSizeValueText" Text="20" Margin="10,0,0,0"/>
            </StackPanel>
            
            <TextBlock Text="对齐方式：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="LeftAlignRadio" Content="左对齐" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton x:Name="CenterAlignRadio" Content="居中" Margin="0,0,20,0"/>
                <RadioButton x:Name="RightAlignRadio" Content="右对齐"/>
            </StackPanel>
            
            <TextBlock Text="目标日期：" Margin="0,10,0,5"/>
            <DatePicker x:Name="TargetDatePicker"/>
            
            <TextBlock Text="备注：" Margin="0,10,0,5"/>
            <TextBox x:Name="RemarkTextBox" Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
            
            <TextBlock Text="备注字号：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="RemarkFontSizeSlider" Minimum="12" Maximum="50" Value="16" Width="200"/>
                <TextBlock x:Name="RemarkFontSizeValueText" Text="16" Margin="10,0,0,0"/>
            </StackPanel>
            
            <TextBlock Text="显示选项：" Margin="0,15,0,5"/>
            <StackPanel>
                <CheckBox x:Name="ShowMessageCheckBox" Content="显示班主任寄语" IsChecked="True" Margin="0,5,0,0"/>
                <CheckBox x:Name="ShowCountdownCheckBox" Content="显示倒计时" IsChecked="True" Margin="0,5,0,0"/>
                <CheckBox x:Name="ShowRemarkCheckBox" Content="显示备注" IsChecked="True" Margin="0,5,0,0"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="SaveButton" Content="保存" Click="SaveButton_Click" Width="100"/>
                <Button x:Name="CancelButton" Content="取消" Click="CancelButton_Click" Width="100" Margin="20,0,0,0"/>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>