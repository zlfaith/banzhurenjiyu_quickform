<Window x:Class="DesktopMessageApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="700" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="班主任寄语（每行一条）：" Margin="0,10,0,5"/>
            <TextBox x:Name="MessageTextBox" Height="150"/>
            
            <TextBlock Text="倒计时名称：" Margin="0,10,0,5"/>
            <TextBox x:Name="CountdownNameTextBox"/>
            
            <TextBlock Text="寄语字号：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="FontSizeSlider" Minimum="12" Maximum="50" Value="18" Width="200"/>
                <TextBlock x:Name="FontSizeValueText" Text="18" Margin="10,0,0,0"/>
            </StackPanel>
            
            <TextBlock Text="倒计时字号：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="CountdownFontSizeSlider" Minimum="12" Maximum="50" Value="20" Width="200"/>
                <TextBlock x:Name="CountdownFontSizeValueText" Text="20" Margin="10,0,0,0"/>
            </StackPanel>
            
            <TextBlock Text="对齐方式：" Margin="0,10,0,5"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="LeftAlignRadio" Content="左对齐" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton x:Name="CenterAlignRadio" Content="居中" Margin="0,0,20,0"/>
                <RadioButton x:Name="RightAlignRadio" Content="右对齐"/>
            </StackPanel>
            
            <TextBlock Text="目标日期：" Margin="0,10,0,5"/>
            <DatePicker x:Name="TargetDatePicker"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="SaveButton" Content="保存" Click="SaveButton_Click" Width="100"/>
                <Button x:Name="CancelButton" Content="取消" Click="CancelButton_Click" Width="100" Margin="20,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>